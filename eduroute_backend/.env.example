PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eduroute_db
JWT_SECRET=replace_with_a_real_secret
JWT_EXPIRES_IN=1d
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:5173
CLIENT_ORIGIN=http://localhost:5173
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
MAIL_FROM=EduRoute <your_email@gmail.com>
RESET_CODE_TTL_MINUTES=15
BCRYPT_SALT_ROUNDS=12
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
SEARCH_PROVIDER=geoapify
SEARCH_PROVIDER_API_KEY=your_geoapify_api_key
MAPBOX_SECRET_TOKEN=sk.your_mapbox_secret_token
MAPBOX_DIRECTIONS_PROFILE=mapbox/driving
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"
FCM_WEB_PUSH_LINK=https://edu-route.vercel.app
